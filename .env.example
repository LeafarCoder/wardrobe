# Required before exposing Wardrobe to the internet. Use a unique, randomly
# generated password (20+ characters). This value stays on the server.
WARDROBE_ACCESS_PASSWORD=

# Local default. On Railway, attach a volume at /data and set this to /data.
WARDROBE_DATA_DIR=data
# Set temporarily to true to analyze stored originals that predate smart framing.
WARDROBE_BACKFILL_ORIGINAL_FOCUS=false

# Recommended low-cost OpenRouter setup.
WARDROBE_AI_PROVIDER=openrouter
WARDROBE_AI_CONCURRENCY=2
OPENROUTER_API_KEY=
OPENROUTER_VISION_MODEL=google/gemini-3.1-flash-lite
OPENROUTER_GARMENT_MODEL=google/gemini-3.1-flash-lite-image
OPENROUTER_MODELED_MODEL=google/gemini-3.1-flash-lite-image
OPENROUTER_IMAGE_QUALITY=auto
OPENROUTER_ZDR=true

# Optional: pin image requests to a specific OpenRouter provider tag.
# With the Google models above and ZDR enabled, Wardrobe automatically uses
# google-vertex/global so photos are not routed through Google AI Studio.
# OPENROUTER_IMAGE_PROVIDER=google-vertex/global

# Direct OpenAI remains supported. Uncomment this block and change the provider.
# WARDROBE_AI_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_VISION_MODEL=gpt-5.4-mini
# OPENAI_IMAGE_MODEL=gpt-image-2
# OPENAI_IMAGE_QUALITY=high

# Optional first-run profile name and legacy reference bootstrap.
# After startup, add/edit users and their 1-3 reference photos in the app.
# WARDROBE_DEFAULT_USER_NAME=My wardrobe
WARDROBE_MODEL_REFERENCE=data/model-reference.png

# A comma-separated list takes precedence over the single legacy reference.
# WARDROBE_MODEL_REFERENCES=data/model-front.jpg,data/model-three-quarter.jpg,data/model-full-body.jpg
